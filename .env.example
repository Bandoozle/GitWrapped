# Auth.js / NextAuth
AUTH_SECRET=generate-with-openssl-rand-base64-32
# Local: http://localhost:3000 — Production: https://your-domain.vercel.app
AUTH_URL=http://localhost:3000

# GitHub OAuth App — https://github.com/settings/developers
# Local callback:  http://localhost:3000/api/auth/callback/github
# Prod callback:   https://your-domain.vercel.app/api/auth/callback/github
# Tip: create two OAuth Apps (local + production), or add both callback URLs if supported.
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Vercel Blob — REQUIRED for live share links on Vercel
# Local without this falls back to .data/shares/ on disk.
# Vercel project → Storage → Blob → connect → redeploy
# https://vercel.com/docs/storage/vercel-blob
BLOB_READ_WRITE_TOKEN=
